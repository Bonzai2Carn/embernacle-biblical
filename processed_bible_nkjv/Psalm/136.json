{
  "verses": [
    {
      "verse_num": 1,
      "segments": [
        {
          "type": "prayer",
          "text": "Oh, give thanks to the Lord, for He is good!",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "For His mercy endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 2,
      "segments": [
        {
          "type": "prayer",
          "text": "Oh, give thanks to the God of gods!",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "For His mercy endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 3,
      "segments": [
        {
          "type": "prayer",
          "text": "Oh, give thanks to the Lord of lords!",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "For His mercy endures forever:",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 4,
      "segments": [
        {
          "type": "prayer",
          "text": "To Him who alone does great wonders,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "For His mercy endures forever;",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 5,
      "segments": [
        {
          "type": "prayer",
          "text": "To Him who by wisdom made the heavens,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "For His mercy endures forever;",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 6,
      "segments": [
        {
          "type": "prayer",
          "text": "To Him who laid out the earth above the waters,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "For His mercy endures forever;",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 7,
      "segments": [
        {
          "type": "prayer",
          "text": "To Him who made great lights,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "For His mercy endures forever—",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 8,
      "segments": [
        {
          "type": "prayer",
          "text": "The sun to rule by day,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "For His mercy endures forever;",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 9,
      "segments": [
        {
          "type": "prayer",
          "text": "The moon and stars to rule by night,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "For His mercy endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 10,
      "segments": [
        {
          "type": "prayer",
          "text": "To Him who struck Egypt in their firstborn,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "For His mercy endures forever;",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 11,
      "segments": [
        {
          "type": "prayer",
          "text": "And brought out Israel from among them,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "For His mercy endures forever;",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 12,
      "segments": [
        {
          "type": "prayer",
          "text": "With a strong hand, and with an outstretched arm,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "For His mercy endures forever;",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 13,
      "segments": [
        {
          "type": "prayer",
          "text": "To Him who divided the Red Sea in two,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "For His mercy endures forever;",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 14,
      "segments": [
        {
          "type": "prayer",
          "text": "And made Israel pass through the midst of it,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "For His mercy endures forever;",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 15,
      "segments": [
        {
          "type": "prayer",
          "text": "But overthrew Pharaoh and his army in the Red Sea,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "For His mercy endures forever;",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 16,
      "segments": [
        {
          "type": "prayer",
          "text": "To Him who led His people through the wilderness,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "For His mercy endures forever;",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 17,
      "segments": [
        {
          "type": "prayer",
          "text": "To Him who struck down great kings,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "For His mercy endures forever;",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 18,
      "segments": [
        {
          "type": "prayer",
          "text": "And slew famous kings,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "For His mercy endures forever—",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 19,
      "segments": [
        {
          "type": "prayer",
          "text": "Sihon king of the Amorites,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "For His mercy endures forever;",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 20,
      "segments": [
        {
          "type": "prayer",
          "text": "And Og king of Bashan,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "For His mercy endures forever—",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 21,
      "segments": [
        {
          "type": "prayer",
          "text": "And gave their land as a heritage,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "For His mercy endures forever;",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 22,
      "segments": [
        {
          "type": "prayer",
          "text": "A heritage to Israel His servant,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "For His mercy endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 23,
      "segments": [
        {
          "type": "prayer",
          "text": "Who remembered us in our lowly state,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "For His mercy endures forever;",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 24,
      "segments": [
        {
          "type": "prayer",
          "text": "And rescued us from our enemies,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "For His mercy endures forever;",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 25,
      "segments": [
        {
          "type": "prayer",
          "text": "Who gives food to all flesh,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "For His mercy endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 26,
      "segments": [
        {
          "type": "prayer",
          "text": "Oh, give thanks to the God of heaven!",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "For His mercy endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}