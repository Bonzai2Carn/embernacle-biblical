{
  "verses": [
    {
      "verse_num": 1,
      "segments": [
        {
          "type": "prayer",
          "text": "Praise the Lord!",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "Praise, O servants of the Lord,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "Praise the name of the Lord!",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 2,
      "segments": [
        {
          "type": "prayer",
          "text": "Blessed be the name of the Lord From this time forth and forevermore!",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 3,
      "segments": [
        {
          "type": "narrative",
          "text": "From the rising of the sun to its going down"
        },
        {
          "type": "divine",
          "text": "The Lord's name is to be praised.",
          "speaker": "The Lord"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 4,
      "segments": [
        {
          "type": "narrative",
          "text": "The Lord is high above all nations,"
        },
        {
          "type": "divine",
          "text": "His glory above the heavens.",
          "speaker": "The Lord"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 5,
      "segments": [
        {
          "type": "narrative",
          "text": "Who is like the Lord our God,"
        },
        {
          "type": "divine",
          "text": "Who dwells on high,",
          "speaker": "The Lord"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 6,
      "segments": [
        {
          "type": "divine",
          "text": "Who humbles Himself to behold The things that are in the heavens and in the earth?",
          "speaker": "The Lord"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 7,
      "segments": [
        {
          "type": "narrative",
          "text": "He raises the poor out of the dust,"
        },
        {
          "type": "divine",
          "text": "And lifts the needy out of the ash heap,",
          "speaker": "The Lord"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 8,
      "segments": [
        {
          "type": "divine",
          "text": "That He may seat him with princes— With the princes of His people.",
          "speaker": "The Lord"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 9,
      "segments": [
        {
          "type": "divine",
          "text": "He grants the barren woman a home, Like a joyful mother of children.",
          "speaker": "The Lord"
        },
        {
          "type": "prayer",
          "text": "Praise the Lord!",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}