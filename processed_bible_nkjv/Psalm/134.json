      "segments": [
        {
          "type": "narrative",
          "text": "Behold,"
        },
        {
          "type": "divine",
          "text": "bless the Lord,",
          "speaker": "Psalmist"
        },
        {
          "type": "narrative",
          "text": "All you servants of the Lord,"
        },
        {
          "type": "narrative",
          "text": "Who by night stand in the house of the Lord!"
