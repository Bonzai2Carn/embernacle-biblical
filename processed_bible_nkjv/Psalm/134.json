      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 2,
      "segments": [
        {
          "type": "divine",
          "text": "Lift up your hands in the sanctuary, And bless the Lord.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 3,
      "segments": [
        {
          "type": "narrative",
          "text": "The Lord who made heaven and earth"
        },
        {
          "type": "divine",
          "text": "Bless you from Zion!",
          "speaker": "The Lord"
        }
      ],
      "footnotes": [],
