{
  "verses": [
    {
      "verse_num": 1,
      "segments": [
        {
          "type": "narrative",
          "text": "The Lord reigns,"
        },
        {
          "type": "divine",
          "text": "He is clothed with majesty;",
          "speaker": "The Lord"
        },
        {
          "type": "narrative",
          "text": "The Lord is clothed,"
        },
        {
          "type": "divine",
          "text": "He has girded Himself with strength.",
          "speaker": "The Lord"
        },
        {
          "type": "narrative",
          "text": "Surely the world is established, so that it cannot be moved."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 2,
      "segments": [
        {
          "type": "divine",
          "text": "Your throne is established from of old;",
          "speaker": "God"
        },
        {
          "type": "divine",
          "text": "You are from everlasting.",
          "speaker": "God"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 3,
      "segments": [
        {
          "type": "narrative",
          "text": "The floods have lifted up, O Lord,"
        },
        {
          "type": "narrative",
          "text": "The floods have lifted up their voice;"
        },
        {
          "type": "narrative",
          "text": "The floods lift up their waves."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 4,
      "segments": [
        {
          "type": "divine",
          "text": "The Lord on high is mightier Than the noise of many waters, Than the mighty waves of the sea.",
          "speaker": "The Lord"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 5,
      "segments": [
        {
          "type": "divine",
          "text": "Your testimonies are very sure;",
          "speaker": "God"
        },
        {
          "type": "narrative",
          "text": "Holiness adorns Your house, O Lord, forever."
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}