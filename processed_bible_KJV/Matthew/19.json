{
  "verses": [
    {
      "verse_num": 1,
      "segments": [
        {
          "type": "narrative",
          "text": "And it came to pass, that when Jesus had finished these sayings, he departed from Galilee, and came into the coasts of Judaea beyond Jordan;"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 2,
      "segments": [
        {
          "type": "narrative",
          "text": "And great multitudes followed him; and he healed them there."
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 3,
      "segments": [
        {
          "type": "narrative",
          "text": "The Pharisees also came unto him, tempting him, and saying unto him,"
        },
        {
          "type": "speech",
          "text": "Is it lawful for a man to put away his wife for every cause?",
          "speaker": "Pharisees"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": [
        "Marriage and Divorce"
      ]
    },
    {
      "verse_num": 4,
      "segments": [
        {
          "type": "narrative",
          "text": "And he answered and said unto them,"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 7,
      "segments": [
        {
          "type": "speech",
          "text": "Why did Moses then command to give a writing of divorcement, and to put her away?",
          "speaker": "Pharisees"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 8,
      "segments": [
        {
          "type": "narrative",
          "text": "He saith unto them,"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 10,
      "segments": [
        {
          "type": "speech",
          "text": "If the case of the man be so with his wife, it is not good to marry.",
          "speaker": "Disciples"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": [
        "Disciples' Response"
      ]
    },
    {
      "verse_num": 11,
      "segments": [
        {
          "type": "narrative",
          "text": "But he said unto them,"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 13,
      "segments": [
        {
          "type": "narrative",
          "text": "Then were there brought unto him little children, that he should put his hands on them, and pray: and the disciples rebuked them."
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": [
        "Jesus and the Children"
      ]
    },
    {
      "verse_num": 14,
      "segments": [
        {
          "type": "narrative",
          "text": "But Jesus said,"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 15,
      "segments": [
        {
          "type": "narrative",
          "text": "And he laid his hands on them, and departed thence."
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 16,
      "segments": [
        {
          "type": "narrative",
          "text": "And, behold, one came and said unto him,"
        },
        {
          "type": "speech",
          "text": "Good Master, what good thing shall I do, that I may have eternal life?",
          "speaker": "Young Man"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": [
        "The Rich Young Ruler"
      ]
    },
    {
      "verse_num": 17,
      "segments": [
        {
          "type": "narrative",
          "text": "And he said unto him,"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 18,
      "segments": [
        {
          "type": "speech",
          "text": "Which?",
          "speaker": "Young Man"
        },
        {
          "type": "divine",
          "text": "",
          "speaker": "Jesus"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 20,
      "segments": [
        {
          "type": "speech",
          "text": "All these things have I kept from my youth up: what lack I yet?",
          "speaker": "Young Man"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 21,
      "segments": [
        {
          "type": "narrative",
          "text": "Jesus said unto him,"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 22,
      "segments": [
        {
          "type": "narrative",
          "text": "But when the young man heard that saying, he went away sorrowful: for he had great possessions."
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 23,
      "segments": [
        {
          "type": "narrative",
          "text": "Then said Jesus unto his disciples,"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": [
        "Wealth and the Kingdom"
      ]
    },
    {
      "verse_num": 25,
      "segments": [
        {
          "type": "speech",
          "text": "Who then can be saved?",
          "speaker": "Disciples"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 26,
      "segments": [
        {
          "type": "narrative",
          "text": "But Jesus beheld them, and said unto them,"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 27,
      "segments": [
        {
          "type": "speech",
          "text": "Behold, we have forsaken all, and followed thee; what shall we have therefore?",
          "speaker": "Peter"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": [
        "Rewards for the Disciples"
      ]
    },
    {
      "verse_num": 28,
      "segments": [
        {
          "type": "narrative",
          "text": "And Jesus said unto them,"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    }
  ]
}