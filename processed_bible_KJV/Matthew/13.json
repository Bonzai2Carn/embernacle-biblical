{
  "verses": [
    {
      "verse_num": 1,
      "segments": [
        {
          "type": "narrative",
          "text": "The same day went Jesus out of the house, and sat by the sea side."
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 2,
      "segments": [
        {
          "type": "narrative",
          "text": "And great multitudes were gathered together unto him, so that he went into a ship, and sat; and the whole multitude stood on the shore."
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 3,
      "segments": [
        {
          "type": "narrative",
          "text": "And he spake many things unto them"
        },
        {
          "type": "sermon",
          "text": "in parables",
          "speaker": "Jesus"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 10,
      "segments": [
        {
          "type": "speech",
          "text": "Why speakest thou unto them in parables?",
          "speaker": "Disciples"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 11,
      "segments": [
        {
          "type": "narrative",
          "text": "He answered"
        },
        {
          "type": "speech",
          "text": "and said unto them",
          "speaker": "Jesus"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 24,
      "segments": [
        {
          "type": "narrative",
          "text": "Another parable put he forth unto them"
        },
        {
          "type": "sermon",
          "text": "saying",
          "speaker": "Jesus"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": [
        "Parable of the Sower"
      ]
    },
    {
      "verse_num": 31,
      "segments": [
        {
          "type": "narrative",
          "text": "Another parable put he forth unto them"
        },
        {
          "type": "sermon",
          "text": "saying",
          "speaker": "Jesus"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": [
        "Parable of the Mustard Seed"
      ]
    },
    {
      "verse_num": 33,
      "segments": [
        {
          "type": "narrative",
          "text": "Another parable spake he unto them"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": [
        "Parable of the Leaven"
      ]
    },
    {
      "verse_num": 34,
      "segments": [
        {
          "type": "narrative",
          "text": "All these things spake Jesus unto the multitude in parables; and without a parable spake he not unto them"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 36,
      "segments": [
        {
          "type": "narrative",
          "text": "Then Jesus sent the multitude away, and went into the house"
        },
        {
          "type": "speech",
          "text": "Declare unto us the parable of the tares of the field",
          "speaker": "Disciples"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 37,
      "segments": [
        {
          "type": "narrative",
          "text": "He answered"
        },
        {
          "type": "speech",
          "text": "and said unto them",
          "speaker": "Jesus"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 51,
      "segments": [
        {
          "type": "speech",
          "text": "Jesus saith unto them",
          "speaker": "Jesus"
        },
        {
          "type": "speech",
          "text": "Yea, Lord",
          "speaker": "Disciples"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 52,
      "segments": [
        {
          "type": "narrative",
          "text": "Then said he unto them"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 53,
      "segments": [
        {
          "type": "narrative",
          "text": "And it came to pass, that when Jesus had finished these parables, he departed thence."
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": [
        "Jesus Teaches in Parables"
      ]
    },
    {
      "verse_num": 54,
      "segments": [
        {
          "type": "narrative",
          "text": "And when he was come into his own country, he taught them in their synagogue, insomuch that they were astonished"
        },
        {
          "type": "speech",
          "text": "Whence hath this man this wisdom, and these mighty works?",
          "speaker": "People"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 57,
      "segments": [
        {
          "type": "narrative",
          "text": "And they were offended in him"
        },
        {
          "type": "speech",
          "text": "But Jesus said unto them",
          "speaker": "Jesus"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 58,
      "segments": [
        {
          "type": "narrative",
          "text": "And he did not many mighty works there because of their unbelief."
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    }
  ]
}