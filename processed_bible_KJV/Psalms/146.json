{
  "verses": [
    {
      "verse_num": 1,
      "segments": [
        {
          "type": "prayer",
          "text": "Praise the Lord! Praise the Lord, O my soul!",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [
        "Praise ye…: Heb. Hallelujah"
      ],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 2,
      "segments": [
        {
          "type": "prayer",
          "text": "I will praise the Lord as long as I live; I will sing praises to my God while I have my being.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 3,
      "segments": [
        {
          "type": "narrative",
          "text": "Put not your trust in princes,"
        },
        {
          "type": "speech",
          "text": "in a son of man, in whom there is no help.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [
        "help: or, salvation"
      ],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 4,
      "segments": [
        {
          "type": "narrative",
          "text": "When his breath departs, he returns to the earth;"
        },
        {
          "type": "narrative",
          "text": "on that very day his plans perish."
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 5,
      "segments": [
        {
          "type": "narrative",
          "text": "Blessed is he whose help is the God of Jacob,"
        },
        {
          "type": "narrative",
          "text": "whose hope is in the Lord his God,"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 6,
      "segments": [
        {
          "type": "narrative",
          "text": "who made heaven and earth, the sea, and all that is in them,"
        },
        {
          "type": "narrative",
          "text": "who keeps faith forever;"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 7,
      "segments": [
        {
          "type": "narrative",
          "text": "who executes justice for the oppressed,"
        },
        {
          "type": "narrative",
          "text": "who gives food to the hungry."
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 8,
      "segments": [
        {
          "type": "narrative",
          "text": "The Lord sets the prisoners free;"
        },
        {
          "type": "narrative",
          "text": "the Lord opens the eyes of the blind."
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 9,
      "segments": [
        {
          "type": "narrative",
          "text": "The Lord lifts up those who are bowed down;"
        },
        {
          "type": "narrative",
          "text": "the Lord loves the righteous."
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 10,
      "segments": [
        {
          "type": "narrative",
          "text": "The Lord watches over the sojourners;"
        },
        {
          "type": "narrative",
          "text": "he upholds the widow and the fatherless,"
        },
        {
          "type": "narrative",
          "text": "but the way of the wicked he brings to ruin."
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    }
  ]
}