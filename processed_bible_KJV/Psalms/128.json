{
  "verses": [
    {
      "verse_num": 1,
      "segments": [
        {
          "type": "narrative",
          "text": "A song of ascents."
        },
        {
          "type": "narrative",
          "text": "Blessed are all who fear the LORD, who walk in obedience to him."
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": [
        "A Song of Ascents"
      ]
    },
    {
      "verse_num": 2,
      "segments": [
        {
          "type": "narrative",
          "text": "You will eat the fruit of your labor; blessings and prosperity will be yours."
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 3,
      "segments": [
        {
          "type": "narrative",
          "text": "Your wife will be like a fruitful vine within your house; your children will be like olive shoots around your table."
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 4,
      "segments": [
        {
          "type": "narrative",
          "text": "Yes, this will be the blessing for the man who fears the LORD."
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 5,
      "segments": [
        {
          "type": "narrative",
          "text": "May the LORD bless you from Zion; may you see the prosperity of Jerusalem all the days of your life."
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 6,
      "segments": [
        {
          "type": "narrative",
          "text": "May you live to see your children's children— peace be on Israel."
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    }
  ]
}