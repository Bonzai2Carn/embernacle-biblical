      "verse_num": 1,
      "segments": [
        {
          "type": "narrative",
          "text": "LORD, who may abide in your tent? Who may dwell on your holy hill?"
        }
      ],
      "footnotes": [
        "abide: Heb. sojourn"
      ],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 2,
      "segments": [
        {
          "type": "narrative",
          "text": "He who walks blamelessly and does what is right"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 3,
      "segments": [
        {
          "type": "narrative",
          "text": "who speaks truth in his heart"
        }
      ],
      "footnotes": [
        "taketh…: or, receiveth, or, endureth"
      ],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 4,
      "segments": [
        {
          "type": "narrative",
          "text": "who does not slander with his tongue and does no evil to his neighbor"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 5,
      "segments": [
        {
          "type": "narrative",
          "text": "who despises a vile person, but honors those who fear the LORD"
        }
      ],
      "footnotes": [],
