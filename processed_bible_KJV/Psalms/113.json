{
  "verses": [
    {
      "verse_num": 1,
      "segments": [
        {
          "type": "divine",
          "text": "Praise the Lord!",
          "speaker": "Psalmist"
        },
        {
          "type": "narrative",
          "text": "Praise, O servants of the Lord, praise the name of the Lord!"
        }
      ],
      "footnotes": [
        "Praise ye: Heb. Hallelujah"
      ],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 2,
      "segments": [
        {
          "type": "narrative",
          "text": "Blessed be the name of the Lord from this time forth and forevermore!"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 3,
      "segments": [
        {
          "type": "narrative",
          "text": "From the rising of the sun to its setting, the name of the Lord is to be praised!"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 4,
      "segments": [
        {
          "type": "narrative",
          "text": "The Lord is high above all nations, and his glory above the heavens!"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 5,
      "segments": [
        {
          "type": "narrative",
          "text": "Who is like the Lord our God, who is seated on high,"
        }
      ],
      "footnotes": [
        "dwelleth: Heb. exalteth himself to dwell"
      ],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 6,
      "segments": [
        {
          "type": "narrative",
          "text": "who looks far down on the heavens and the earth?"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 7,
      "segments": [
        {
          "type": "narrative",
          "text": "He raises the poor from the dust and lifts the needy from the ash heap,"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 8,
      "segments": [
        {
          "type": "narrative",
          "text": "to make them sit with princes, with the princes of his people."
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 9,
      "segments": [
        {
          "type": "narrative",
          "text": "He gives the barren woman a home, making her the joyous mother of children."
        }
      ],
      "footnotes": [
        "to keep: Heb. to dwell in an house"
      ],
      "references": [],
      "heading": []
    }
  ]
}