{
  "verses": [
    {
      "verse_num": 1,
      "segments": [
        {
          "type": "narrative",
          "text": "A Song of Ascents."
        },
        {
          "type": "narrative",
          "text": "Those who trust in the LORD are like Mount Zion,"
        },
        {
          "type": "narrative",
          "text": "which cannot be moved, but abides forever."
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": [
        "Song of Ascents"
      ]
    },
    {
      "verse_num": 2,
      "segments": [
        {
          "type": "narrative",
          "text": "As the mountains surround Jerusalem,"
        },
        {
          "type": "narrative",
          "text": "so the LORD surrounds his people,"
        },
        {
          "type": "narrative",
          "text": "from this time forth and forevermore."
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 3,
      "segments": [
        {
          "type": "narrative",
          "text": "For the scepter of wickedness shall not rest on the land allotted to the righteous,"
        },
        {
          "type": "narrative",
          "text": "lest the righteous stretch out their hands to do wrong."
        }
      ],
      "footnotes": [
        "the wicked: Heb. wickedness"
      ],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 4,
      "segments": [
        {
          "type": "narrative",
          "text": "Do good, O LORD, to those who are good,"
        },
        {
          "type": "prayer",
          "text": "and to those who are upright in their hearts!",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 5,
      "segments": [
        {
          "type": "narrative",
          "text": "But those who turn aside to their crooked ways"
        },
        {
          "type": "narrative",
          "text": "the LORD will lead away with evildoers."
        },
        {
          "type": "narrative",
          "text": "Peace be upon Israel!"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    }
  ]
}