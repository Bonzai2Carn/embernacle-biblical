{
  "verses": [
    {
      "verse_num": 1,
      "segments": [
        {
          "type": "narrative",
          "text": "A Song of Ascents."
        },
        {
          "type": "narrative",
          "text": "When the LORD restored the fortunes of Zion,"
        },
        {
          "type": "narrative",
          "text": "we were like those who dream."
        }
      ],
      "footnotes": [
        "turned…: Heb. returned the returning"
      ],
      "references": [],
      "heading": [
        "A Song of Ascents"
      ]
    },
    {
      "verse_num": 2,
      "segments": [
        {
          "type": "narrative",
          "text": "Then our mouth was filled with laughter,"
        },
        {
          "type": "narrative",
          "text": "and our tongue with shouts of joy;"
        },
        {
          "type": "narrative",
          "text": "then they said among the nations,"
        },
        {
          "type": "speech",
          "text": "The LORD has done great things for them.",
          "speaker": "Nations"
        }
      ],
      "footnotes": [
        "hath…: Heb. hath magnified to do with them"
      ],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 3,
      "segments": [
        {
          "type": "narrative",
          "text": "The LORD has done great things for us;"
        },
        {
          "type": "narrative",
          "text": "we are glad."
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 4,
      "segments": [
        {
          "type": "narrative",
          "text": "Restore our fortunes, O LORD,"
        },
        {
          "type": "prayer",
          "text": "like streams in the Negeb!",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 5,
      "segments": [
        {
          "type": "narrative",
          "text": "Those who sow in tears"
        },
        {
          "type": "narrative",
          "text": "shall reap with shouts of joy!"
        }
      ],
      "footnotes": [
        "joy: or, singing"
      ],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 6,
      "segments": [
        {
          "type": "narrative",
          "text": "He who goes out weeping,"
        },
        {
          "type": "narrative",
          "text": "bearing the seed for sowing,"
        },
        {
          "type": "narrative",
          "text": "shall come home with shouts of joy,"
        },
        {
          "type": "narrative",
          "text": "bringing his sheaves with him."
        }
      ],
      "footnotes": [
        "precious…: or, seed basket"
      ],
      "references": [],
      "heading": []
    }
  ]
}