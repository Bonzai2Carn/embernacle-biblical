{
  "verses": [
    {
      "verse_num": 1,
      "segments": [
        {
          "type": "divine",
          "text": "spake unto Moses, saying",
          "speaker": "The LORD"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 2,
      "segments": [
        {
          "type": "narrative",
          "text": "This shall be the law of the leper in the day of his cleansing:"
        },
        {
          "type": "narrative",
          "text": "He shall be brought unto the priest"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 3,
      "segments": [
        {
          "type": "narrative",
          "text": "And the priest shall go forth out of the camp; and the priest shall look, and, behold, if the plague of leprosy be healed in the leper"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 4,
      "segments": [
        {
          "type": "narrative",
          "text": "Then shall the priest command to take for him that is to be cleansed"
        },
        {
          "type": "narrative",
          "text": "two birds alive and clean, and cedar wood, and scarlet, and hyssop"
        }
      ],
      "footnotes": [
        "birds: or, sparrows"
      ],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 33,
      "segments": [
        {
          "type": "divine",
          "text": "spake unto Moses and unto Aaron, saying",
          "speaker": "The LORD"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": [
        "Leprosy in Houses"
      ]
    },
    {
      "verse_num": 54,
      "segments": [
        {
          "type": "narrative",
          "text": "This is the law for all manner of plague of leprosy, and scall"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 57,
      "segments": [
        {
          "type": "narrative",
          "text": "To teach when it is unclean, and when it is clean: this is the law of leprosy"
        }
      ],
      "footnotes": [
        "when it is unclean…: Heb. in the day of the unclean, and in the day of the clean"
      ],
      "references": [],
      "heading": []
    }
  ]
}