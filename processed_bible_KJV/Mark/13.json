      "verse_num": 1,
      "segments": [
        {
          "type": "narrative",
          "text": "And as he went out of the temple, one of his disciples saith unto him,"
        },
        {
          "type": "speech",
          "text": "Master, see what manner of stones and what buildings are here!",
          "speaker": "Disciple"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 2,
      "segments": [
        {
          "type": "narrative",
          "text": "And Jesus answering said unto him,"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 3,
      "segments": [
        {
          "type": "narrative",
          "text": "And as he sat upon the mount of Olives over against the temple, Peter and James and John and Andrew asked him privately,"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 4,
      "segments": [
        {
          "type": "speech",
          "text": "Tell us, when shall these things be? and what shall be the sign when all these things shall be fulfilled?",
          "speaker": "Peter, James, John, and Andrew"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
