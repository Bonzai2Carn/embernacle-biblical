{
  "verses": [
    {
      "verse_num": 1,
      "segments": [
        {
          "type": "narrative",
          "text": "Then said the high priest,"
        },
        {
          "type": "speech",
          "text": "Are these things so?",
          "speaker": "High Priest"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 2,
      "segments": [
        {
          "type": "speech",
          "text": "Men, brethren, and fathers, hearken;",
          "speaker": "Stephen"
        },
        {
          "type": "narrative",
          "text": "The God of glory appeared unto our father Abraham, when he was in Mesopotamia, before he dwelt in Charran,"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 3,
      "segments": [
        {
          "type": "divine",
          "text": "Get thee out of thy country, and from thy kindred, and come into the land which I shall shew thee.",
          "speaker": "God"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 37,
      "segments": [
        {
          "type": "narrative",
          "text": "This is that Moses,"
        },
        {
          "type": "prophetic",
          "text": "which said unto the children of Israel, A prophet shall the Lord your God raise up unto you of your brethren, like unto me; him shall ye hear.",
          "speaker": "Moses"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": [
        "Prophecy of the Coming Prophet"
      ]
    },
    {
      "verse_num": 51,
      "segments": [
        {
          "type": "sermon",
          "text": "Ye stiffnecked and uncircumcised in heart and ears, ye do always resist the Holy Ghost: as your fathers did, so do ye.",
          "speaker": "Stephen"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": [
        "Stephen's Condemnation"
      ]
    },
    {
      "verse_num": 55,
      "segments": [
        {
          "type": "narrative",
          "text": "But he, being full of the Holy Ghost, looked up stedfastly into heaven, and saw the glory of God, and Jesus standing on the right hand of God,"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 56,
      "segments": [
        {
          "type": "speech",
          "text": "Behold, I see the heavens opened, and the Son of man standing on the right hand of God.",
          "speaker": "Stephen"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 59,
      "segments": [
        {
          "type": "prayer",
          "text": "Lord Jesus, receive my spirit.",
          "speaker": "Stephen"
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    },
    {
      "verse_num": 60,
      "segments": [
        {
          "type": "prayer",
          "text": "Lord, lay not this sin to their charge.",
          "speaker": "Stephen"
        },
        {
          "type": "narrative",
          "text": "And when he had said this, he fell asleep."
        }
      ],
      "footnotes": [],
      "references": [],
      "heading": []
    }
  ]
}