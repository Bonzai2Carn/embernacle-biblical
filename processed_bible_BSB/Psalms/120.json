{
  "verses": [
    {
      "type": "heading",
      "text": [
        "In My Distress I Cried to the LORD"
      ]
    },
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "In my distress I cried to the LORD, and He answered me."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "Deliver my soul, O LORD, from lying lips and a deceitful tongue."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "What will He do to you, and what will be added to you,\nO deceitful tongue?"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "Sharp arrows will come from the warrior, with burning coals of the broom tree!"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "Woe to me that I dwell in Meshech, that I live among the tents of Kedar!"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "Too long have I dweltamong those who hate peace."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "7",
      "segments": [
        {
          "type": "hymnal",
          "text": "I am in favor of peace; but when I speak, they want war."
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}