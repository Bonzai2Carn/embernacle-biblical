{
  "verses": [
    {
      "type": "heading",
      "text": [
        "By the Rivers of Babylon"
      ]
    },
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "By the rivers of Babylon we sat and weptwhen we remembered Zion."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "There on the willows we hung our harps,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "for there our captors requested a song; our tormentors demanded songs of joy:"
        },
        {
          "type": "speech",
          "text": "Sing us a song of Zion.",
          "speaker": "Babylonian Captors"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "How can we sing a song of the LORDin a foreign land?"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "If I forget you, O Jerusalem, may my right hand cease to function."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "May my tongue cling to the roof of my mouthif I do not remember you, if I do not exalt Jerusalemas my greatest joy!"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "7",
      "segments": [
        {
          "type": "hymnal",
          "text": "Remember, O LORD, the sons of Edom on the day Jerusalem fell:"
        },
        {
          "type": "speech",
          "text": "Destroy it,",
          "speaker": "Unknown"
        },
        {
          "type": "hymnal",
          "text": "they said,"
        },
        {
          "type": "speech",
          "text": "tear it down to its foundations!",
          "speaker": "Unknown"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "8",
      "segments": [
        {
          "type": "hymnal",
          "text": "O Daughter of Babylon, doomed to destruction, blessed is he who repays youas you have done to us."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "9",
      "segments": [
        {
          "type": "hymnal",
          "text": "Blessed is he who seizes your infants and dashes them against the rocks."
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}