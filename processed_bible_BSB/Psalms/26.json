{
  "verses": [
    {
      "type": "heading",
      "text": [
        "Vindicate Me, O LORD"
      ]
    },
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "Vindicate me, O LORD!\nFor I have walked with integrity; I have trusted in the LORD without wavering."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "Test me, O LORD, and try me; examine my heart[^58] and mind."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "For Your loving devotion is before my eyes, and I have walked in Your truth."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "I do not sit with deceitful men, nor keep company with hypocrites."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "I hate the mob of evildoers, and refuse to sit with the wicked."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "I wash my hands in innocencethat I may go about Your altar, O LORD,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "7",
      "segments": [
        {
          "type": "hymnal",
          "text": "to raise my voice in thanksgiving and declare all Your wonderful works."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "8",
      "segments": [
        {
          "type": "hymnal",
          "text": "O LORD, I love the house where You dwell, the place where Your glory resides."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "9",
      "segments": [
        {
          "type": "hymnal",
          "text": "Do not take my soul away with sinners, or my life with men of bloodshed,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "10",
      "segments": [
        {
          "type": "hymnal",
          "text": "in whose hands are wicked schemes, whose right hands are full of bribes."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "11",
      "segments": [
        {
          "type": "hymnal",
          "text": "But I will walk with integrity; redeem me and be merciful to me."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "12",
      "segments": [
        {
          "type": "hymnal",
          "text": "My feet st and on level ground; in the congregations I will bless the LORD."
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}