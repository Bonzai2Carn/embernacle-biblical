{
  "verses": [
    {
      "type": "heading",
      "text": [
        "His Loving Devotion Endures Forever"
      ]
    },
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "Give thanks to the LORD, for He is good. His loving devotion endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "Give thanks to the God of gods. His loving devotion endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "Give thanks to the Lord of lords. His loving devotion endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "He alone does great wonders. His loving devotion endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "By His insight He made the heavens. His loving devotion endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "He spread out the earth upon the waters. His loving devotion endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "7",
      "segments": [
        {
          "type": "hymnal",
          "text": "He made the great lights—His loving devotion endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "8",
      "segments": [
        {
          "type": "hymnal",
          "text": "the sun to rule the day, His loving devotion endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "9",
      "segments": [
        {
          "type": "hymnal",
          "text": "the moon and stars to govern the night. His loving devotion endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "10",
      "segments": [
        {
          "type": "hymnal",
          "text": "He struck down the firstborn of EgyptHis loving devotion endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "11",
      "segments": [
        {
          "type": "hymnal",
          "text": "and brought Israel out from among themHis loving devotion endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "12",
      "segments": [
        {
          "type": "hymnal",
          "text": "with a mighty hand and an outstretched arm. His loving devotion endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "13",
      "segments": [
        {
          "type": "hymnal",
          "text": "He divided the Red Sea in twoHis loving devotion endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "14",
      "segments": [
        {
          "type": "hymnal",
          "text": "and led Israel through the midst, His loving devotion endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "15",
      "segments": [
        {
          "type": "hymnal",
          "text": "but swept Pharaoh and his army into the Red Sea. His loving devotion endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "16",
      "segments": [
        {
          "type": "hymnal",
          "text": "He led His people through the wilderness. His loving devotion endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "17",
      "segments": [
        {
          "type": "hymnal",
          "text": "He struck down great kingsHis loving devotion endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "18",
      "segments": [
        {
          "type": "hymnal",
          "text": "and slaughtered mighty kings—His loving devotion endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "19",
      "segments": [
        {
          "type": "hymnal",
          "text": "Sihon king of the AmoritesHis loving devotion endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "20",
      "segments": [
        {
          "type": "hymnal",
          "text": "and Og king of Bashan—His loving devotion endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "21",
      "segments": [
        {
          "type": "hymnal",
          "text": "and He gave their land as an inheritance, His loving devotion endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "22",
      "segments": [
        {
          "type": "hymnal",
          "text": "a heritage to His servant Israel. His loving devotion endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "23",
      "segments": [
        {
          "type": "hymnal",
          "text": "He remembered us in our low estateHis loving devotion endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "24",
      "segments": [
        {
          "type": "hymnal",
          "text": "and freed us from our enemies. His loving devotion endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "25",
      "segments": [
        {
          "type": "hymnal",
          "text": "He gives food to every creature. His loving devotion endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "26",
      "segments": [
        {
          "type": "hymnal",
          "text": "Give thanks to the God of heaven! His loving devotion endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}