{
  "verses": [
    {
      "type": "heading",
      "text": [
        "To Your Name Be the Glory"
      ]
    },
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "Not to us, O LORD, not to us, but to Your name be the glory, because of Your loving devotion, because of Your faithfulness."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "Why should the nations say,"
        },
        {
          "type": "speech",
          "text": "Where is their God?",
          "speaker": "Unknown"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "Our God is in heaven; He does as He pleases."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "Their idols are silver and gold, made by the hands of men."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "They have mouths, but cannot speak; they have eyes, but cannot see;"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "they have ears, but cannot hear; they have noses, but cannot smell;"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "7",
      "segments": [
        {
          "type": "hymnal",
          "text": "they have hands, but cannot feel; they have feet, but cannot walk;\nthey cannot even clear their throats.[^243]"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "8",
      "segments": [
        {
          "type": "hymnal",
          "text": "Those who make them become like them, as do all who trust in them."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "9",
      "segments": [
        {
          "type": "hymnal",
          "text": "O Israel,[^244] trust in the LORD! He is their help and shield."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "10",
      "segments": [
        {
          "type": "hymnal",
          "text": "O house of Aaron, trust in the LORD! He is their help and shield."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "11",
      "segments": [
        {
          "type": "hymnal",
          "text": "You who fear the LORD, trust in the LORD! He is their help and shield."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "12",
      "segments": [
        {
          "type": "hymnal",
          "text": "The LORD is mindful of us; He will bless us. He will bless the house of Israel; He will bless the house of Aaron;"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "13",
      "segments": [
        {
          "type": "hymnal",
          "text": "He will bless those who fear the LORD—small and great alike."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "14",
      "segments": [
        {
          "type": "hymnal",
          "text": "May the LORD give you increase, both you and your children."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "15",
      "segments": [
        {
          "type": "hymnal",
          "text": "May you be blessed by the LORD, the Maker of heaven and earth."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "16",
      "segments": [
        {
          "type": "hymnal",
          "text": "The highest heavens belong to the LORD, but the earth He has given to mankind."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "17",
      "segments": [
        {
          "type": "hymnal",
          "text": "It is not the dead who praise the LORD, nor any who descend into silence."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "18",
      "segments": [
        {
          "type": "hymnal",
          "text": "But it is we who will bless the LORD, both now and forevermore.\nHallelujah![^245]"
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}