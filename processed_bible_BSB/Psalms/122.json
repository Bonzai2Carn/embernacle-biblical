{
  "verses": [
    {
      "type": "heading",
      "text": [
        "Pray for the Peace of Jerusalem"
      ]
    },
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "I was glad when they said to me,"
        },
        {
          "type": "speech",
          "text": "Let us go to the house of the LORD.",
          "speaker": "Unknown"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "Our feet are standing in your gates, O Jerusalem."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "Jerusalem is built upas a city united together,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "where the tribes go up, the tribes of the LORD, as a testimony for Israel, to give thanks to the name of the LORD."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "For there the thrones of judgment st and, the thrones of the house of David."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "Pray for the peace of Jerusalem:"
        },
        {
          "type": "speech",
          "text": "May those who love you prosper.",
          "speaker": "Unknown"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "7",
      "segments": [
        {
          "type": "speech",
          "text": "May there be peace within your walls, and prosperity inside your fortresses.",
          "speaker": "David"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "8",
      "segments": [
        {
          "type": "hymnal",
          "text": "For the sake of my brothers and friends, I will say,"
        },
        {
          "type": "speech",
          "text": "Peace be within you.",
          "speaker": "Unknown"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "9",
      "segments": [
        {
          "type": "hymnal",
          "text": "For the sake of the house of the LORD our God, I will seek your prosperity."
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}