{
  "verses": [
    {
      "type": "heading",
      "text": [
        "Ascribe Glory to the LORD"
      ]
    },
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "Ascribe to the LORD, O heavenly beings,  ascribe to the LORD glory and strength."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "Ascribe to the LORD the glory due His name; worship the LORD in the splendor of His holiness. "
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "The voice of the LORD is over the waters; the God of glory thunders;\nthe LORD is heard over many waters."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "The voice of the LORD is powerful; the voice of the LORD is majestic."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "The voice of the LORD breaks the cedars; the LORD shatters the cedars of Lebanon."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "He makes Lebanon skip like a calf, and Sirion like a young wild ox."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "7",
      "segments": [
        {
          "type": "hymnal",
          "text": "The voice of the LORDstrikes with flames of fire."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "8",
      "segments": [
        {
          "type": "hymnal",
          "text": "The voice of the LORD shakes the wilderness; the LORD shakes the Wilderness of Kadesh."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "9",
      "segments": [
        {
          "type": "hymnal",
          "text": "The voice of the LORD twists the oaks and strips the forests bare.\nAnd in His temple all cry,"
        },
        {
          "type": "speech",
          "text": "Glory!",
          "speaker": "Unknown"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "10",
      "segments": [
        {
          "type": "hymnal",
          "text": "The LORD sits enthroned over the flood; the LORD is enthroned as King forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "11",
      "segments": [
        {
          "type": "hymnal",
          "text": "The LORD gives His people strength; the LORD blesses His people with peace."
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}