{
  "verses": [
    {
      "type": "heading",
      "text": [
        "Deliver Me, O LORD!"
      ]
    },
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "O LORD, how my foes have increased! How many rise up against me!"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "Many say of me,"
        },
        {
          "type": "speech",
          "text": "God will not deliver him.",
          "speaker": "Unknown"
        },
        {
          "type": "hymnal",
          "text": "Selah[^6]"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "But You, O LORD, are a shield around me, my glory, and the One who lifts my head."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "To the LORD I cry aloud, and He answers me from His holy mountain. Selah"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "I lie down and sleep; I wake again, for the LORD sustains me."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "I will not fear the myriadsset against me on every side."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "7",
      "segments": [
        {
          "type": "hymnal",
          "text": "Arise, O LORD! Save me, O my God! Strike all my enemies on the jaw; break the teeth of the wicked."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "8",
      "segments": [
        {
          "type": "hymnal",
          "text": "Salvation belongs to the LORD; may Your blessing be on Your people. Selah"
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}