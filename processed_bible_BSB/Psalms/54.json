{
  "verses": [
    {
      "type": "heading",
      "text": [
        "Save Me by Your Name"
      ]
    },
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "Save me, O God, by Your name, and vindicate me by Your might!"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "Hear my prayer, O God; listen to the words of my mouth."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "For strangers rise up against me, and ruthless men seek my life—\nmen with no regard for God. Selah"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "Surely God is my helper; the Lord is the sustainer of my soul."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "He will reward my enemies with evil. In Your faithfulness, destroy them."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "Freely I will sacrifice to You; I will praise Your name, O LORD, for it is good."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "7",
      "segments": [
        {
          "type": "hymnal",
          "text": "For He has delivered me from every trouble, and my eyes have stared down my foes."
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}