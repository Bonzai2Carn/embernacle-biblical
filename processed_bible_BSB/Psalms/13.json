{
  "verses": [
    {
      "type": "heading",
      "text": [
        "How Long, O LORD?"
      ]
    },
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "How long, O LORD? Will You forget me forever?\nHow long will You hide Your face from me?"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "How long must I wrestle in my soul, with sorrow in my heart each day?\nHow long will my enemy dominate me?"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "Consider me and respond, O LORD my God. Give light to my eyes, lest I sleep in death,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "lest my enemy say,"
        },
        {
          "type": "speech",
          "text": "I have overcome him,",
          "speaker": "Unknown"
        },
        {
          "type": "hymnal",
          "text": "and my foes rejoice when I fall."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "But I have trusted in Your loving devotion; my heart will rejoice in Your salvation."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "I will sing to the LORD, for He has been good to me."
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}