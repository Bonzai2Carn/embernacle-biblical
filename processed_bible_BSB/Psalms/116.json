{
  "verses": [
    {
      "type": "heading",
      "text": [
        "The LORD Has Heard My Voice"
      ]
    },
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "I love the LORD, for He has heard my voice—my appeal for mercy."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "Because He has inclined His ear to me, I will call on Him as long as I live."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "The ropes of death entangled me; the anguish of Sheol overcame me;\nI was confronted by trouble and sorrow."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "Then I called on the name of the LORD:"
        },
        {
          "type": "prayer",
          "text": "O LORD, deliver my soul!",
          "speaker": "Unknown"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "The LORD is gracious and righteous; our God is full of compassion."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "The LORD preserves the simplehearted; I was helpless, and He saved me."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "7",
      "segments": [
        {
          "type": "hymnal",
          "text": "Return to your rest, O my soul, for the LORD has been good to you."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "8",
      "segments": [
        {
          "type": "hymnal",
          "text": "For You have delivered my soul from death, my eyes from tears, my feet from stumbling."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "9",
      "segments": [
        {
          "type": "hymnal",
          "text": "I will walk before the LORDin the land of the living."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "10",
      "segments": [
        {
          "type": "hymnal",
          "text": "I believed, therefore I said,[^246]"
        },
        {
          "type": "speech",
          "text": "I am greatly afflicted.",
          "speaker": "Unknown"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "11",
      "segments": [
        {
          "type": "hymnal",
          "text": "In my alarm I said,"
        },
        {
          "type": "speech",
          "text": "All men are liars!",
          "speaker": "Unknown"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "12",
      "segments": [
        {
          "type": "hymnal",
          "text": "How can I repay the LORDfor all His goodness to me?"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "13",
      "segments": [
        {
          "type": "hymnal",
          "text": "I will lift the cup of salvation and call on the name of the LORD."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "14",
      "segments": [
        {
          "type": "hymnal",
          "text": "I will fulfill my vows to the LORDin the presence of all His people."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "15",
      "segments": [
        {
          "type": "hymnal",
          "text": "Precious in the sight of the LORDis the death of His saints."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "16",
      "segments": [
        {
          "type": "hymnal",
          "text": "Truly, O LORD, I am Your servant; I am Your servant, the son of Your maidservant;\nYou have broken my bonds."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "17",
      "segments": [
        {
          "type": "hymnal",
          "text": "I will offer to You a sacrifice of thanksgiving and call on the name of the LORD."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "18",
      "segments": [
        {
          "type": "hymnal",
          "text": "I will fulfill my vows to the LORDin the presence of all His people,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "19",
      "segments": [
        {
          "type": "hymnal",
          "text": "in the courts of the LORD’s house, in your midst, O Jerusalem.\nHallelujah![^247]"
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}