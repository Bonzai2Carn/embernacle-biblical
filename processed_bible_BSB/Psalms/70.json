{
  "verses": [
    {
      "type": "heading",
      "text": [
        "Hurry, O LORD, to Help Me!"
      ]
    },
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "Make haste, O God, to deliver me! Hurry, O LORD, to help me!"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "May those who seek my lifebe ashamed and confounded; may those who wish me harmbe repelled and humiliated."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "May those who say,"
        },
        {
          "type": "speech",
          "text": "Aha, aha!",
          "speaker": "Unknown"
        },
        {
          "type": "hymnal",
          "text": "retreat because of their shame."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "May all who seek Yourejoice and be glad in You; may those who love Your salvation always say,"
        },
        {
          "type": "speech",
          "text": "Let God be magnified!",
          "speaker": "Unknown"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "But I am poor and needy; hurry to me, O God. You are my help and my deliverer; O LORD, do not delay."
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}