{
  "verses": [
    {
      "type": "heading",
      "text": [
        "I Lift Up My Eyes to the Hills"
      ]
    },
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "I lift up my eyes to the hills. From where does my help come?"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "My help comes from the LORD, the Maker of heaven and earth."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "He will not allow your foot to slip; your Protector will not slumber."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "Behold, the Protector of Israelwill neither slumber nor sleep."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "The LORD is your keeper; the LORD is the shade on your right hand."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "The sun will not strike you by day, nor the moon by night."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "7",
      "segments": [
        {
          "type": "hymnal",
          "text": "The LORD will guard you from all evil; He will preserve your soul."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "8",
      "segments": [
        {
          "type": "hymnal",
          "text": "The LORD will watch over your coming and going, both now and forevermore."
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}