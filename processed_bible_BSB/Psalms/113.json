{
  "verses": [
    {
      "type": "heading",
      "text": [
        "The LORD Exalts the Humble"
      ]
    },
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "Hallelujah![^242]\nGive praise, O servants of the LORD; praise the name of the LORD."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "Blessed be the name of the LORDboth now and forevermore."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "From where the sun rises to where it sets, the name of the LORD is praised."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "The LORD is exalted over all the nations, His glory above the heavens."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "Who is like the LORD our God, the One enthroned on high?"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "He humbles Himself to beholdthe heavens and the earth."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "7",
      "segments": [
        {
          "type": "hymnal",
          "text": "He raises the poor from the dust and lifts the needy from the dump"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "8",
      "segments": [
        {
          "type": "hymnal",
          "text": "to seat them with nobles, with the princes of His people."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "9",
      "segments": [
        {
          "type": "hymnal",
          "text": "He settles the barren woman in her homeas a joyful mother to her children.\nHallelujah!"
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}