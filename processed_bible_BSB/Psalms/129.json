{
  "verses": [
    {
      "type": "heading",
      "text": [
        "The Cords of the Wicked"
      ]
    },
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "Many a time they have persecuted me from my youth—let Israel now declare—"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "many a time they have persecuted me from my youth, but they have not prevailed against me."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "The plowmen plowed over my back; they made their furrows long."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "The LORD is righteous; He has cut me from the cords of the wicked."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "May all who hate Zionbe turned back in shame."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "May they be like grass on the rooftops, which withers before it can grow,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "7",
      "segments": [
        {
          "type": "hymnal",
          "text": "unable to fill the hands of the reaper, or the arms of the binder of sheaves."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "8",
      "segments": [
        {
          "type": "hymnal",
          "text": "May none who pass by say to them,"
        },
        {
          "type": "speech",
          "text": "The blessing of the LORD be on you;\nwe bless you in the name of the LORD.",
          "speaker": "Unknown"
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}