{
  "verses": [
    {
      "verse_num": 1,
      "segments": [
        {
          "type": "prayer",
          "text": "Give thanks to the Lord, for he is good.",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "His love endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 2,
      "segments": [
        {
          "type": "prayer",
          "text": "Give thanks to the God of gods.",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "His love endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 3,
      "segments": [
        {
          "type": "prayer",
          "text": "Give thanks to the Lord of lords:",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "His love endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 4,
      "segments": [
        {
          "type": "prayer",
          "text": "to him who alone does great wonders,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "His love endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 5,
      "segments": [
        {
          "type": "prayer",
          "text": "who by his understanding made the heavens,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "His love endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 6,
      "segments": [
        {
          "type": "prayer",
          "text": "who spread out the earth upon the waters,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "His love endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 7,
      "segments": [
        {
          "type": "prayer",
          "text": "who made the great lights—",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "His love endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 8,
      "segments": [
        {
          "type": "prayer",
          "text": "the sun to govern the day,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "His love endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 9,
      "segments": [
        {
          "type": "prayer",
          "text": "the moon and stars to govern the night;",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "His love endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 10,
      "segments": [
        {
          "type": "prayer",
          "text": "to him who struck down the firstborn of Egypt",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "His love endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 11,
      "segments": [
        {
          "type": "prayer",
          "text": "and brought Israel out from among them",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "His love endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 12,
      "segments": [
        {
          "type": "prayer",
          "text": "with a mighty hand and outstretched arm;",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "His love endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 13,
      "segments": [
        {
          "type": "prayer",
          "text": "to him who divided the Red Sea asunder",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "His love endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 14,
      "segments": [
        {
          "type": "prayer",
          "text": "and brought Israel through the midst of it,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "His love endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 15,
      "segments": [
        {
          "type": "prayer",
          "text": "but swept Pharaoh and his army into the Red Sea;",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "His love endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 16,
      "segments": [
        {
          "type": "prayer",
          "text": "to him who led his people through the wilderness;",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "His love endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 17,
      "segments": [
        {
          "type": "prayer",
          "text": "to him who struck down great kings,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "His love endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 18,
      "segments": [
        {
          "type": "prayer",
          "text": "and killed mighty kings—",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "His love endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 19,
      "segments": [
        {
          "type": "prayer",
          "text": "Sihon king of the Amorites",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "His love endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 20,
      "segments": [
        {
          "type": "prayer",
          "text": "and Og king of Bashan—",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "His love endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 21,
      "segments": [
        {
          "type": "prayer",
          "text": "and gave their land as an inheritance,",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "His love endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 22,
      "segments": [
        {
          "type": "prayer",
          "text": "an inheritance to his servant Israel.",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "His love endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 23,
      "segments": [
        {
          "type": "prayer",
          "text": "He remembered us in our low estate",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "His love endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 24,
      "segments": [
        {
          "type": "prayer",
          "text": "and freed us from our enemies.",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "His love endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 25,
      "segments": [
        {
          "type": "prayer",
          "text": "He gives food to every creature.",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "His love endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 26,
      "segments": [
        {
          "type": "prayer",
          "text": "Give thanks to the God of heaven.",
          "speaker": "Psalmist"
        },
        {
          "type": "prayer",
          "text": "His love endures forever.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
