{
  "verses": [
    {
      "verse_num": 1,
      "segments": [
        {
          "type": "narrative",
          "text": "When the Lord restored the fortunes of Zion,"
        },
        {
          "type": "narrative",
          "text": "we were like those who dreamed."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 2,
      "segments": [
        {
          "type": "narrative",
          "text": "Our mouths were filled with laughter, our tongues with songs of joy."
        },
        {
          "type": "narrative",
          "text": "Then it was said among the nations,"
        },
        {
          "type": "speech",
          "text": "The Lord has done great things for them.",
          "speaker": "Nations"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 3,
      "segments": [
        {
          "type": "narrative",
          "text": "The Lord has done great things for us,"
        },
        {
          "type": "narrative",
          "text": "and we are filled with joy."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 4,
      "segments": [
        {
          "type": "prayer",
          "text": "Restore our fortunes, Lord, like streams in the Negev.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 5,
      "segments": [
        {
          "type": "narrative",
          "text": "Those who sow with tears will reap with songs of joy."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 6,
      "segments": [
        {
          "type": "narrative",
          "text": "Those who go out weeping, carrying seed to sow,"
        },
        {
          "type": "narrative",
          "text": "will return with songs of joy, carrying sheaves with them."
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}