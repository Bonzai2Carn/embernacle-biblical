{
  "verses": [
    {
      "verse_num": 1,
      "segments": [
        {
          "type": "narrative",
          "text": "If the Lord had not been on our side—"
        },
        {
          "type": "speech",
          "text": "let Israel say—",
          "speaker": "Israel"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 2,
      "segments": [
        {
          "type": "narrative",
          "text": "if the Lord had not been on our side when people attacked us,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 3,
      "segments": [
        {
          "type": "narrative",
          "text": "they would have swallowed us alive when their anger flared against us;"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 4,
      "segments": [
        {
          "type": "narrative",
          "text": "the flood would have engulfed us, the torrent would have swept over us,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 5,
      "segments": [
        {
          "type": "narrative",
          "text": "the raging waters would have swept us away."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 6,
      "segments": [
        {
          "type": "prayer",
          "text": "Praise be to the Lord, who has not let us be torn by their teeth.",
          "speaker": "Israel"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 7,
      "segments": [
        {
          "type": "narrative",
          "text": "We have escaped like a bird from the fowler's snare;"
        },
        {
          "type": "narrative",
          "text": "the snare has been broken, and we have escaped."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 8,
      "segments": [
        {
          "type": "prayer",
          "text": "Our help is in the name of the Lord, the Maker of heaven and earth.",
          "speaker": "Israel"
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}