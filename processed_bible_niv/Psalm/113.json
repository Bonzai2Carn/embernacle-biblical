{
  "verses": [
    {
      "verse_num": 1,
      "segments": [
        {
          "type": "narrative",
          "text": "Praise the Lord."
        },
        {
          "type": "divine",
          "text": "Praise the Lord, you his servants; praise the name of the Lord.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 2,
      "segments": [
        {
          "type": "divine",
          "text": "Let the name of the Lord be praised, both now and forevermore.",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 3,
      "segments": [
        {
          "type": "narrative",
          "text": "From the rising of the sun to the place where it sets, the name of the Lord is to be praised."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 4,
      "segments": [
        {
          "type": "narrative",
          "text": "The Lord is exalted over all the nations, his glory above the heavens."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 5,
      "segments": [
        {
          "type": "narrative",
          "text": "Who is like the Lord our God, the One who sits enthroned on high,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 6,
      "segments": [
        {
          "type": "narrative",
          "text": "who stoops down to look on the heavens and the earth?"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 7,
      "segments": [
        {
          "type": "narrative",
          "text": "He raises the poor from the dust and lifts the needy from the ash heap;"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 8,
      "segments": [
        {
          "type": "narrative",
          "text": "he seats them with princes, with the princes of his people."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 9,
      "segments": [
        {
          "type": "narrative",
          "text": "He settles the childless woman in her home as a happy mother of children."
        },
        {
          "type": "narrative",
          "text": "Praise the Lord."
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}