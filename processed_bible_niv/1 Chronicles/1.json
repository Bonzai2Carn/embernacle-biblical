{
  "verses": [
    {
      "verse_num": 1,
      "segments": [
        {
          "type": "narrative",
          "text": "Adam, Seth, Enosh,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 2,
      "segments": [
        {
          "type": "narrative",
          "text": "Kenan, Mahalalel, Jared,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 3,
      "segments": [
        {
          "type": "narrative",
          "text": "Enoch, Methuselah, Lamech, Noah."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 4,
      "segments": [
        {
          "type": "narrative",
          "text": "The sons of Noah: Shem, Ham and Japheth."
        }
      ],
      "title": "The Japhethites",
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 5,
      "segments": [
        {
          "type": "narrative",
          "text": "The sons of Japheth: Gomer, Magog, Madai, Javan, Tubal, Meshek and Tiras."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 6,
      "segments": [
        {
          "type": "narrative",
          "text": "The sons of Gomer: Ashkenaz, Riphath and Togarmah."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 7,
      "segments": [
        {
          "type": "narrative",
          "text": "The sons of Javan: Elishah, Tarshish, the Kittites and the Rodanites."
        }
      ],
      "title": "The Hamites",
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 8,
      "segments": [
        {
          "type": "narrative",
          "text": "The sons of Ham: Cush, Egypt, Put and Canaan."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 9,
      "segments": [
        {
          "type": "narrative",
          "text": "The sons of Cush: Seba, Havilah, Sabta, Raamah and Sabteka. The sons of Raamah: Sheba and Dedan."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 10,
      "segments": [
        {
          "type": "narrative",
          "text": "Cush was the father of Nimrod, who became a mighty warrior on earth."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 11,
      "segments": [
        {
          "type": "narrative",
          "text": "Egypt was the father of the Ludites, Anamites, Lehabites, Naphtuhites,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 12,
      "segments": [
        {
          "type": "narrative",
          "text": "Pathrusites, Kasluhites (from whom the Philistines came) and Caphtorites."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 13,
      "segments": [
        {
          "type": "narrative",
          "text": "Canaan was the father of Sidon his firstborn, and of the Hittites,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 14,
      "segments": [
        {
          "type": "narrative",
          "text": "Jebusites, Amorites, Girgashites,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 15,
      "segments": [
        {
          "type": "narrative",
          "text": "Hivites, Arkites, Sinites,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 16,
      "segments": [
        {
          "type": "narrative",
          "text": "Arvadites, Zemarites and Hamathites."
        }
      ],
      "title": "The Semites",
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 17,
      "segments": [
        {
          "type": "narrative",
          "text": "The sons of Shem: Elam, Ashur, Arphaxad, Lud and Aram. The sons of Aram: Uz, Hul, Gether and Meshek."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 18,
      "segments": [
        {
          "type": "narrative",
          "text": "Arphaxad was the father of Shelah, and Shelah the father of Eber."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 19,
      "segments": [
        {
          "type": "narrative",
          "text": "Two sons were born to Eber: One was named Peleg, because in his time the earth was divided; his brother was named Joktan."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 20,
      "segments": [
        {
          "type": "narrative",
          "text": "Joktan was the father of Almodad, Sheleph, Hazarmaveth, Jerah,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 21,
      "segments": [
        {
          "type": "narrative",
          "text": "Hadoram, Uzal, Diklah,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 22,
      "segments": [
        {
          "type": "narrative",
          "text": "Obal, Abimael, Sheba,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 23,
      "segments": [
        {
          "type": "narrative",
          "text": "Ophir, Havilah and Jobab. All these were sons of Joktan."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 24,
      "segments": [
        {
          "type": "narrative",
          "text": "Shem, Arphaxad, Shelah,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 25,
      "segments": [
        {
          "type": "narrative",
          "text": "Eber, Peleg, Reu,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 26,
      "segments": [
        {
          "type": "narrative",
          "text": "Serug, Nahor, Terah"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 27,
      "segments": [
        {
          "type": "narrative",
          "text": "and Abram (that is, Abraham)."
        }
      ],
      "title": "The Family of Abraham",
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 28,
      "segments": [
        {
          "type": "narrative",
          "text": "The sons of Abraham: Isaac and Ishmael."
        }
      ],
      "title": "Descendants of Hagar",
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 29,
      "segments": [
        {
          "type": "narrative",
          "text": "These were their descendants: Nebaioth the firstborn of Ishmael, Kedar, Adbeel, Mibsam,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 30,
      "segments": [
        {
          "type": "narrative",
          "text": "Mishma, Dumah, Massa, Hadad, Tema,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 31,
      "segments": [
        {
          "type": "narrative",
          "text": "Jetur, Naphish and Kedemah. These were the sons of Ishmael."
        }
      ],
      "title": "Descendants of Keturah",
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 32,
      "segments": [
        {
          "type": "narrative",
          "text": "The sons born to Keturah, Abraham’s concubine: Zimran, Jokshan, Medan, Midian, Ishbak and Shuah. The sons of Jokshan: Sheba and Dedan."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 33,
      "segments": [
        {
          "type": "narrative",
          "text": "The sons of Midian: Ephah, Epher, Hanok, Abida and Eldaah. All these were descendants of Keturah."
        }
      ],
      "title": "Descendants of Sarah",
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 34,
      "segments": [
        {
          "type": "narrative",
          "text": "Abraham was the father of Isaac. The sons of Isaac: Esau and Israel."
        }
      ],
      "title": "Esau’s Sons",
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 35,
      "segments": [
        {
          "type": "narrative",
          "text": "The sons of Esau: Eliphaz, Reuel, Jeush, Jalam and Korah."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 36,
      "segments": [
        {
          "type": "narrative",
          "text": "The sons of Eliphaz: Teman, Omar, Zepho, Gatam and Kenaz; by Timna: Amalek."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 37,
      "segments": [
        {
          "type": "narrative",
          "text": "The sons of Reuel: Nahath, Zerah, Shammah and Mizzah."
        }
      ],
      "title": "The People of Seir in Edom",
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 38,
      "segments": [
        {
          "type": "narrative",
          "text": "The sons of Seir: Lotan, Shobal, Zibeon, Anah, Dishon, Ezer and Dishan."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 39,
      "segments": [
        {
          "type": "narrative",
          "text": "The sons of Lotan: Hori and Homam. Timna was Lotan’s sister."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 40,
      "segments": [
        {
          "type": "narrative",
          "text": "The sons of Shobal: Alvan, Manahath, Ebal, Shepho and Onam. The sons of Zibeon: Aiah and Anah."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 41,
      "segments": [
        {
          "type": "narrative",
          "text": "The son of Anah: Dishon. The sons of Dishon: Hemdan, Eshban, Ithran and Keran."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 42,
      "segments": [
        {
          "type": "narrative",
          "text": "The sons of Ezer: Bilhan, Zaavan and Akan. The sons of Dishan: Uz and Aran."
        }
      ],
      "title": "The Rulers of Edom",
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 43,
      "segments": [
        {
          "type": "narrative",
          "text": "These were the kings who reigned in Edom before any Israelite king reigned: Bela son of Beor, whose city was named Dinhabah."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 44,
      "segments": [
        {
          "type": "narrative",
          "text": "When Bela died, Jobab son of Zerah from Bozrah succeeded him as king."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 45,
      "segments": [
        {
          "type": "narrative",
          "text": "When Jobab died, Husham from the land of the Temanites succeeded him as king."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 46,
      "segments": [
        {
          "type": "narrative",
          "text": "When Husham died, Hadad son of Bedad, who defeated Midian in the country of Moab, succeeded him as king. His city was named Avith."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 47,
      "segments": [
        {
          "type": "narrative",
          "text": "When Hadad died, Samlah from Masrekah succeeded him as king."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 48,
      "segments": [
        {
          "type": "narrative",
          "text": "When Samlah died, Shaul from Rehoboth on the river succeeded him as king."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 49,
      "segments": [
        {
          "type": "narrative",
          "text": "When Shaul died, Baal-Hanan son of Akbor succeeded him as king."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 50,
      "segments": [
        {
          "type": "narrative",
          "text": "When Baal-Hanan died, Hadad succeeded him as king. His city was named Pau, and his wife’s name was Mehetabel daughter of Matred, the daughter of Me-Zahab."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 51,
      "segments": [
        {
          "type": "narrative",
          "text": "Hadad also died. The chiefs of Edom were: Timna, Alvah, Jetheth,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 52,
      "segments": [
        {
          "type": "narrative",
          "text": "Oholibamah, Elah, Pinon,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 53,
      "segments": [
        {
          "type": "narrative",
          "text": "Kenaz, Teman, Mibzar,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": 54,
      "segments": [
        {
          "type": "narrative",
          "text": "Magdiel and Iram. These were the chiefs of Edom."
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}