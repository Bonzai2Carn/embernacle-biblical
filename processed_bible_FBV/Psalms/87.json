{
  "verses": [
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "The Lord founded the city on his holy mountain.\n"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "Jerusalem is the city that the Lord loves more than any other city in Israel. [^301]"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "Many wonderful things are said of you, city of God! Selah."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "I mention Egypt[^302] and Babylon as those who know me, and in addition Philistia, Tyre, and Ethiopia—"
        },
        {
          "type": "speech",
          "text": "this man was born there.",
          "speaker": "Unknown"
        },
        {
          "type": "hymnal",
          "text": "[^303]"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "It will be said concerning Jerusalem,"
        },
        {
          "type": "speech",
          "text": "Everyone was born there,",
          "speaker": "Unknown"
        },
        {
          "type": "hymnal",
          "text": "[^304] and the Most High will make it secure."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "When the Lord registers the nations, he will write,"
        },
        {
          "type": "speech",
          "text": "They were born there.",
          "speaker": "Unknown"
        },
        {
          "type": "hymnal",
          "text": "[^305] Selah."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "7",
      "segments": [
        {
          "type": "hymnal",
          "text": "Singers and dancers alike say,"
        },
        {
          "type": "speech",
          "text": "Living here I am at home.",
          "speaker": "Unknown"
        },
        {
          "type": "hymnal",
          "text": "[^306]"
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}