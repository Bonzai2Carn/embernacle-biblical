{
  "verses": [
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "God, save me! Hurry, Lord, help me!\n"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "Please defeat and humiliate the people who are trying to kill me; turn back in disgrace those who want to hurt me."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "May they be shocked at their defeat, those who taunted me."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "But may everyone who comes to you be happy and glad; may those who love your salvation always say,"
        },
        {
          "type": "speech",
          "text": "God is great!",
          "speaker": "Unknown"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "As for me, I am poor and needy. Hurry, God, help me! Save me! Lord, don't wait!"
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}