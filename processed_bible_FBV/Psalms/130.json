{
  "verses": [
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "Lord, I cry out to you from the depths of my pain. [^437]\n"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "Please listen to my cry, and pay attention to what I'm asking."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "Lord, if you kept a list of sins, who could escape being condemned?"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "But you are forgiving so that we might respect you."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "I'm waiting for the Lord, longingly waiting, for I trust in his word."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "I long for the Lord to come, more than watchmen longing for the dawn to come, more than watchmen longing for the dawn to come."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "7",
      "segments": [
        {
          "type": "hymnal",
          "text": "Israel, put your hope in the Lord, for the Lord loves us with a trustworthy love and his salvation knows no limits."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "8",
      "segments": [
        {
          "type": "hymnal",
          "text": "He will save Israel from every sin."
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}