{
  "verses": [
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "How long, Yahweh? Will you forget me forever?"
        },
        {
          "type": "hymnal",
          "text": "How long will you hide your face from me?"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "How long shall I take counsel in my soul, having sorrow in my heart every day?"
        },
        {
          "type": "hymnal",
          "text": "How long shall my enemy triumph over me?"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "Behold, and answer me, Yahweh, my God. Give light to my eyes, lest I sleep in death;"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "lest my enemy say,"
        },
        {
          "type": "speech",
          "text": "I have prevailed against him;",
          "speaker": "Unknown"
        },
        {
          "type": "hymnal",
          "text": "lest my adversaries rejoice when I fall."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "But I trust in your loving kindness. My heart rejoices in your salvation."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "I will sing to Yahweh, because he has been good to me."
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}