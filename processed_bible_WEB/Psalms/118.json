{
  "verses": [
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "Give thanks to Yahweh, for he is good, for his loving kindness endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "Let Israel now saythat his loving kindness endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "Let the house of Aaron now saythat his loving kindness endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "Now let those who fear Yahweh saythat his loving kindness endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "Out of my distress, I called on Yah. Yah answered me with freedom."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "Yahweh is on my side. I will not be afraid. What can man do to me?"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "7",
      "segments": [
        {
          "type": "hymnal",
          "text": "Yahweh is on my side among those who help me. Therefore I will look in triumph at those who hate me."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "8",
      "segments": [
        {
          "type": "hymnal",
          "text": "It is better to take refuge in Yahweh, than to put confidence in man."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "9",
      "segments": [
        {
          "type": "hymnal",
          "text": "It is better to take refuge in Yahweh, than to put confidence in princes."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "10",
      "segments": [
        {
          "type": "hymnal",
          "text": "All the nations surrounded me, but in Yahweh’s name I cut them off."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "11",
      "segments": [
        {
          "type": "hymnal",
          "text": "They surrounded me, yes, they surrounded me. In Yahweh’s name I indeed cut them off."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "12",
      "segments": [
        {
          "type": "hymnal",
          "text": "They surrounded me like bees. They are quenched like the burning thorns."
        },
        {
          "type": "hymnal",
          "text": "In Yahweh’s name I cut them off."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "13",
      "segments": [
        {
          "type": "hymnal",
          "text": "You pushed me back hard, to make me fall, but Yahweh helped me."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "14",
      "segments": [
        {
          "type": "hymnal",
          "text": "Yah is my strength and song. He has become my salvation."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "15",
      "segments": [
        {
          "type": "hymnal",
          "text": "The voice of rejoicing and salvation is in the tents of the righteous.\n"
        },
        {
          "type": "speech",
          "text": "The right hand of Yahweh does valiantly.",
          "speaker": "Unknown"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "16",
      "segments": [
        {
          "type": "speech",
          "text": "The right hand of Yahweh is exalted! The right hand of Yahweh does valiantly!",
          "speaker": "Psalmist"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "17",
      "segments": [
        {
          "type": "hymnal",
          "text": "I will not die, but live, and declare Yah’s works."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "18",
      "segments": [
        {
          "type": "hymnal",
          "text": "Yah has punished me severely, but he has not given me over to death."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "19",
      "segments": [
        {
          "type": "hymnal",
          "text": "Open to me the gates of righteousness. I will enter into them."
        },
        {
          "type": "hymnal",
          "text": "I will give thanks to Yah."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "20",
      "segments": [
        {
          "type": "hymnal",
          "text": "This is the gate of Yahweh; the righteous will enter into it."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "21",
      "segments": [
        {
          "type": "hymnal",
          "text": "I will give thanks to you, for you have answered me, and have become my salvation."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "22",
      "segments": [
        {
          "type": "hymnal",
          "text": "The stone which the builders rejectedhas become the cornerstone. "
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "23",
      "segments": [
        {
          "type": "hymnal",
          "text": "This is Yahweh’s doing. It is marvelous in our eyes."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "24",
      "segments": [
        {
          "type": "hymnal",
          "text": "This is the day that Yahweh has made. We will rejoice and be glad in it!"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "25",
      "segments": [
        {
          "type": "hymnal",
          "text": "Save us now, we beg you, Yahweh! Yahweh, we beg you, send prosperity now."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "26",
      "segments": [
        {
          "type": "hymnal",
          "text": "Blessed is he who comes in Yahweh’s name! We have blessed you out of Yahweh’s house."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "27",
      "segments": [
        {
          "type": "hymnal",
          "text": "Yahweh is God, and he has given us light. Bind the sacrifice with cords, even to the horns of the altar."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "28",
      "segments": [
        {
          "type": "hymnal",
          "text": "You are my God, and I will give thanks to you. You are my God, I will exalt you."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "29",
      "segments": [
        {
          "type": "hymnal",
          "text": "Oh give thanks to Yahweh, for he is good, for his loving kindness endures forever."
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}