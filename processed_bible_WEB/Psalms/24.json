{
  "verses": [
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "The earth is Yahweh’s, with its fullness; the world, and those who dwell in it."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "For he has founded it on the seas, and established it on the floods."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "Who may ascend to Yahweh’s hill? Who may st and in his holy place?"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "He who has clean hands and a pure heart; who has not lifted up his soul to falsehood,"
        },
        {
          "type": "hymnal",
          "text": "and has not sworn deceitfully."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "He shall receive a blessing from Yahweh, righteousness from the God of his salvation."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "This is the generation of those who seek Him, who seek your face—even Jacob. Selah."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "7",
      "segments": [
        {
          "type": "hymnal",
          "text": "Lift up your heads, you gates! Be lifted up, you everlasting doors,"
        },
        {
          "type": "hymnal",
          "text": "and the King of glory will come in."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "8",
      "segments": [
        {
          "type": "hymnal",
          "text": "Who is the King of glory? Yahweh strong and mighty,"
        },
        {
          "type": "hymnal",
          "text": "Yahweh mighty in battle."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "9",
      "segments": [
        {
          "type": "hymnal",
          "text": "Lift up your heads, you gates; yes, lift them up, you everlasting doors,"
        },
        {
          "type": "hymnal",
          "text": "and the King of glory will come in."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "10",
      "segments": [
        {
          "type": "hymnal",
          "text": "Who is this King of glory? Yahweh of Armies is the King of glory! Selah."
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}