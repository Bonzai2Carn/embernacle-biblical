{
  "verses": [
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "May God be merciful to us, bless us, and cause his face to shine on us. Selah."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "That your way may be known on earth, and your salvation among all nations,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "let the peoples praise you, God. Let all the peoples praise you."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "Oh let the nations be glad and sing for joy, for you will judge the peoples with equity,"
        },
        {
          "type": "hymnal",
          "text": "and govern the nations on earth. Selah."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "Let the peoples praise you, God. Let all the peoples praise you."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "The earth has yielded its increase. God, even our own God, will bless us."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "7",
      "segments": [
        {
          "type": "hymnal",
          "text": "God will bless us. All the ends of the earth shall fear him."
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}