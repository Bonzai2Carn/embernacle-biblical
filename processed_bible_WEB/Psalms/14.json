{
  "verses": [
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "The fool has said in his heart, "
        },
        {
          "type": "speech",
          "text": "There is no God.",
          "speaker": "Fool"
        },
        {
          "type": "hymnal",
          "text": "They are corrupt.\nThey have done abominable deeds.\nThere is no one who does good."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "Yahweh looked down from heaven on the children of men, to see if there were any who understood,"
        },
        {
          "type": "hymnal",
          "text": "who sought after God."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "They have all gone aside. They have together become corrupt."
        },
        {
          "type": "hymnal",
          "text": "There is no one who does good, no, not one."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "Have all the workers of iniquity no knowledge, who eat up my people as they eat bread,"
        },
        {
          "type": "hymnal",
          "text": "and don’t call on Yahweh?"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "There they were in great fear, for God is in the generation of the righteous."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "You frustrate the plan of the poor, because Yahweh is his refuge."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "7",
      "segments": [
        {
          "type": "hymnal",
          "text": "Oh that the salvation of Israel would come out of Zion! When Yahweh restores the fortunes of his people,"
        },
        {
          "type": "hymnal",
          "text": "then Jacob shall rejoice, and Israel shall be glad."
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}