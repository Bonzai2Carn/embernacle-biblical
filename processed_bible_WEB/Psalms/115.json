{
  "verses": [
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "Not to us, Yahweh, not to us, but to your name give glory,"
        },
        {
          "type": "hymnal",
          "text": "for your loving kindness, and for your truth’s sake."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "Why should the nations say,\n"
        },
        {
          "type": "speech",
          "text": "Where is their God, now?",
          "speaker": "Unknown"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "But our God is in the heavens. He does whatever he pleases."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "Their idols are silver and gold, the work of men’s hands."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "They have mouths, but they don’t speak. They have eyes, but they don’t see."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "They have ears, but they don’t hear. They have noses, but they don’t smell."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "7",
      "segments": [
        {
          "type": "hymnal",
          "text": "They have hands, but they don’t feel. They have feet, but they don’t walk,"
        },
        {
          "type": "hymnal",
          "text": "neither do they speak through their throat."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "8",
      "segments": [
        {
          "type": "hymnal",
          "text": "Those who make them will be like them; yes, everyone who trusts in them."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "9",
      "segments": [
        {
          "type": "hymnal",
          "text": "Israel, trust in Yahweh! He is their help and their shield."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "10",
      "segments": [
        {
          "type": "hymnal",
          "text": "House of Aaron, trust in Yahweh! He is their help and their shield."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "11",
      "segments": [
        {
          "type": "hymnal",
          "text": "You who fear Yahweh, trust in Yahweh! He is their help and their shield."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "12",
      "segments": [
        {
          "type": "hymnal",
          "text": "Yahweh remembers us. He will bless us. He will bless the house of Israel."
        },
        {
          "type": "hymnal",
          "text": "He will bless the house of Aaron."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "13",
      "segments": [
        {
          "type": "hymnal",
          "text": "He will bless those who fear Yahweh, both small and great."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "14",
      "segments": [
        {
          "type": "hymnal",
          "text": "May Yahweh increase you more and more, you and your children."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "15",
      "segments": [
        {
          "type": "hymnal",
          "text": "Blessed are you by Yahweh, who made heaven and earth."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "16",
      "segments": [
        {
          "type": "hymnal",
          "text": "The heavens are Yahweh’s heavens, but he has given the earth to the children of men."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "17",
      "segments": [
        {
          "type": "hymnal",
          "text": "The dead don’t praise Yah, nor any who go down into silence,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "18",
      "segments": [
        {
          "type": "hymnal",
          "text": "but we will bless Yah, from this time forward and forever more. Praise Yah!"
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}