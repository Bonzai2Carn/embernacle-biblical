{
  "verses": [
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "Shout for joy to Yahweh, all you lands!"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "Serve Yahweh with gladness."
        },
        {
          "type": "hymnal",
          "text": "Come before his presence with singing."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "Know that Yahweh, he is God. It is he who has made us, and we are his."
        },
        {
          "type": "hymnal",
          "text": "We are his people, and the sheep of his pasture."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "Enter into his gates with thanksgiving, and into his courts with praise."
        },
        {
          "type": "hymnal",
          "text": "Give thanks to him, and bless his name."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "For Yahweh is good. His loving kindness endures forever,"
        },
        {
          "type": "hymnal",
          "text": "his faithfulness to all generations."
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}