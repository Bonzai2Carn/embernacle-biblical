{
  "verses": [
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "Oh clap your hands, all you nations. Shout to God with the voice of triumph!"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "For Yahweh Most High is awesome. He is a great King over all the earth."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "He subdues nations under us, and peoples under our feet."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "He chooses our inheritance for us, the glory of Jacob whom he loved. Selah."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "God has gone up with a shout, Yahweh with the sound of a trumpet."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "Sing praises to God! Sing praises! Sing praises to our King! Sing praises!"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "7",
      "segments": [
        {
          "type": "hymnal",
          "text": "For God is the King of all the earth. Sing praises with understanding."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "8",
      "segments": [
        {
          "type": "hymnal",
          "text": "God reigns over the nations. God sits on his holy throne."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "9",
      "segments": [
        {
          "type": "hymnal",
          "text": "The princes of the peoples are gathered together,"
        },
        {
          "type": "hymnal",
          "text": "the people of the God of Abraham. For the shields of the earth belong to God.\nHe is greatly exalted!"
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}