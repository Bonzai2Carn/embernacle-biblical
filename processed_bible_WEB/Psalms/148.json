{
  "verses": [
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "Praise Yah! Praise Yahweh from the heavens!"
        },
        {
          "type": "hymnal",
          "text": "Praise him in the heights!"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "Praise him, all his angels! Praise him, all his army!"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "Praise him, sun and moon! Praise him, all you shining stars!"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "Praise him, you heavens of heavens, you waters that are above the heavens."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "Let them praise Yahweh’s name, for he commanded, and they were created."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "He has also established them forever and ever. He has made a decree which will not pass away."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "7",
      "segments": [
        {
          "type": "hymnal",
          "text": "Praise Yahweh from the earth, you great sea creatures, and all depths,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "8",
      "segments": [
        {
          "type": "hymnal",
          "text": "lightning and hail, snow and clouds, stormy wind, fulfilling his word,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "9",
      "segments": [
        {
          "type": "hymnal",
          "text": "mountains and all hills, fruit trees and all cedars,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "10",
      "segments": [
        {
          "type": "hymnal",
          "text": "wild animals and all livestock, small creatures and flying birds,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "11",
      "segments": [
        {
          "type": "hymnal",
          "text": "kings of the earth and all peoples, princes and all judges of the earth,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "12",
      "segments": [
        {
          "type": "hymnal",
          "text": "both young men and maidens, old men and children."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "13",
      "segments": [
        {
          "type": "hymnal",
          "text": "Let them praise Yahweh’s name, for his name alone is exalted."
        },
        {
          "type": "hymnal",
          "text": "His glory is above the earth and the heavens."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "14",
      "segments": [
        {
          "type": "hymnal",
          "text": "He has lifted up the horn of his people, the praise of all his saints,"
        },
        {
          "type": "hymnal",
          "text": "even of the children of Israel, a people near to him. Praise Yah!"
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}