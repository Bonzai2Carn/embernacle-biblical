{
  "verses": [
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "His foundation is in the holy mountains."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "Yahweh loves the gates of Zion more than all the dwellings of Jacob."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "Glorious things are spoken about you, city of God. Selah."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "I will record Rahab and Babylon among those who acknowledge me. Behold, Philistia, Tyre, and also Ethiopia:"
        },
        {
          "type": "speech",
          "text": "This one was born there.",
          "speaker": "Unknown"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "Yes, of Zion it will be said, "
        },
        {
          "type": "speech",
          "text": "This one and that one was born in her;",
          "speaker": "Yes, of Zion it will be"
        },
        {
          "type": "hymnal",
          "text": "the Most High himself will establish her."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "Yahweh will count, when he writes up the peoples,\n"
        },
        {
          "type": "speech",
          "text": "This one was born there.",
          "speaker": "Yes, of Zion it will be"
        },
        {
          "type": "hymnal",
          "text": "Selah."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "7",
      "segments": [
        {
          "type": "hymnal",
          "text": "Those who sing as well as those who dance say,\n"
        },
        {
          "type": "speech",
          "text": "All my springs are in you.",
          "speaker": "Yes, of Zion it will be"
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}