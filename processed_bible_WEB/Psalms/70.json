{
  "verses": [
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "Hurry, God, to deliver me. Come quickly to help me, Yahweh."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "Let them be disappointed and confounded who seek my soul. Let those who desire my ruin be turned back in disgrace."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "Let them be turned because of their shame who say, "
        },
        {
          "type": "speech",
          "text": "Aha! Aha!",
          "speaker": "Unknown"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "Let all those who seek you rejoice and be glad in you. Let those who love your salvation continually say,"
        },
        {
          "type": "speech",
          "text": "Let God be exalted!",
          "speaker": "Unknown"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "But I am poor and needy. Come to me quickly, God. You are my help and my deliverer. Yahweh, don’t delay."
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}