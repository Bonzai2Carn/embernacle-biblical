{
  "verses": [
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "Yahweh reigns! He is clothed with majesty!"
        },
        {
          "type": "hymnal",
          "text": "Yahweh is armed with strength. The world also is established. It can’t be moved."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "Your throne is established from long ago. You are from everlasting."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "The floods have lifted up, Yahweh, the floods have lifted up their voice."
        },
        {
          "type": "hymnal",
          "text": "The floods lift up their waves."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "Above the voices of many waters, the mighty breakers of the sea,"
        },
        {
          "type": "hymnal",
          "text": "Yahweh on high is mighty."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "Your statutes st and firm. Holiness adorns your house,"
        },
        {
          "type": "hymnal",
          "text": "Yahweh, forever more."
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}