{
  "verses": [
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "Praise Yah! Praise, you servants of Yahweh,"
        },
        {
          "type": "hymnal",
          "text": "praise Yahweh’s name."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "Blessed be Yahweh’s name, from this time forward and forever more."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "From the rising of the sun to its going down, Yahweh’s name is to be praised."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "Yahweh is high above all nations, his glory above the heavens."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "Who is like Yahweh, our God, who has his seat on high,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "who stoops down to see in heaven and in the earth?"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "7",
      "segments": [
        {
          "type": "hymnal",
          "text": "He raises up the poor out of the dust, and lifts up the needy from the ash heap,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "8",
      "segments": [
        {
          "type": "hymnal",
          "text": "that he may set him with princes, even with the princes of his people."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "9",
      "segments": [
        {
          "type": "hymnal",
          "text": "He settles the barren woman in her homeas a joyful mother of children. Praise Yah!"
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}