  "verses": [
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "Look! Praise Yahweh, all you servants of Yahweh, who st and by night in Yahweh’s house!"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "Lift up your hands in the sanctuary. Praise Yahweh!"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "May Yahweh bless you from Zion, even he who made heaven and earth."
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}