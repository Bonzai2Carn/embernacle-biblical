{
  "verses": [
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "Praise Yah! Praise Yahweh, my soul."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "While I live, I will praise Yahweh. I will sing praises to my God as long as I exist."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "Don’t put your trust in princes, in a son of man in whom there is no help."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "His spirit departs, and he returns to the earth. In that very day, his thoughts perish."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "Happy is he who has the God of Jacob for his help, whose hope is in Yahweh, his God,"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "who made heaven and earth, the sea, and all that is in them;"
        },
        {
          "type": "hymnal",
          "text": "who keeps truth forever;"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "7",
      "segments": [
        {
          "type": "hymnal",
          "text": "who executes justice for the oppressed; who gives food to the hungry. Yahweh frees the prisoners."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "8",
      "segments": [
        {
          "type": "hymnal",
          "text": "Yahweh opens the eyes of the blind."
        },
        {
          "type": "hymnal",
          "text": "Yahweh raises up those who are bowed down.\nYahweh loves the righteous."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "9",
      "segments": [
        {
          "type": "hymnal",
          "text": "Yahweh preserves the foreigners. He upholds the fatherless and widow,"
        },
        {
          "type": "hymnal",
          "text": "but he turns the way of the wicked upside down."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "10",
      "segments": [
        {
          "type": "hymnal",
          "text": "Yahweh will reign forever; your God, O Zion, to all generations. Praise Yah!"
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}