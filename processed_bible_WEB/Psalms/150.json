{
  "verses": [
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "Praise Yah! Praise God in his sanctuary!"
        },
        {
          "type": "hymnal",
          "text": "Praise him in his heavens for his acts of power!"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "Praise him for his mighty acts! Praise him according to his excellent greatness!"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "Praise him with the sounding of the trumpet! Praise him with harp and lyre!"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "Praise him with tambourine and dancing! Praise him with stringed instruments and flute!"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "Praise him with loud cymbals! Praise him with resounding cymbals!"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "Let everything that has breath praise Yah! Praise Yah!"
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}