{
  "verses": [
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "hymnal",
          "text": "Sing to Yahweh a new song! Sing to Yahweh, all the earth."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "hymnal",
          "text": "Sing to Yahweh! Bless his name!"
        },
        {
          "type": "hymnal",
          "text": "Proclaim his salvation from day to day!"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "hymnal",
          "text": "Declare his glory among the nations, his marvelous works among all the peoples."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "hymnal",
          "text": "For Yahweh is great, and greatly to be praised! He is to be feared above all gods."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "hymnal",
          "text": "For all the gods of the peoples are idols, but Yahweh made the heavens."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "hymnal",
          "text": "Honor and majesty are before him. Strength and beauty are in his sanctuary."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "7",
      "segments": [
        {
          "type": "hymnal",
          "text": "Ascribe to Yahweh, you families of nations, ascribe to Yahweh glory and strength."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "8",
      "segments": [
        {
          "type": "hymnal",
          "text": "Ascribe to Yahweh the glory due to his name. Bring an offering, and come into his courts."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "9",
      "segments": [
        {
          "type": "hymnal",
          "text": "Worship Yahweh in holy array. Tremble before him, all the earth."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "10",
      "segments": [
        {
          "type": "hymnal",
          "text": "Say among the nations, "
        },
        {
          "type": "speech",
          "text": "Yahweh reigns.",
          "speaker": "Unknown"
        },
        {
          "type": "hymnal",
          "text": "The world is also established.\nIt can’t be moved.\nHe will judge the peoples with equity."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "11",
      "segments": [
        {
          "type": "hymnal",
          "text": "Let the heavens be glad, and let the earth rejoice. Let the sea roar, and its fullness!"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "12",
      "segments": [
        {
          "type": "hymnal",
          "text": "Let the field and all that is in it exult!\nThen all the trees of the woods shall sing for joy"
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "13",
      "segments": [
        {
          "type": "hymnal",
          "text": "before Yahweh; for he comes,\nfor he comes to judge the earth. He will judge the world with righteousness, the peoples with his truth."
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}