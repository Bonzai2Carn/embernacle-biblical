{
  "verses": [
    {
      "verse_num": "1",
      "segments": [
        {
          "type": "narrative",
          "text": "I was small among my brothers, and youngest in my father’s house."
        },
        {
          "type": "narrative",
          "text": "I tended my father’s sheep."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "2",
      "segments": [
        {
          "type": "narrative",
          "text": "My hands formed a musical instrument, and my fingers tuned a lyre."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "3",
      "segments": [
        {
          "type": "narrative",
          "text": "Who shall tell my Lord? The Lord himself, he himself hears."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "4",
      "segments": [
        {
          "type": "narrative",
          "text": "He sent forth his angel and took me from my father’s sheep, and he anointed me with his anointing oil."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "5",
      "segments": [
        {
          "type": "narrative",
          "text": "My brothers were handsome and tall; but the Lord didn’t take pleasure in them."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "6",
      "segments": [
        {
          "type": "narrative",
          "text": "I went out to meet the Philistine, and he cursed me by his idols."
        }
      ],
      "footnotes": [],
      "references": []
    },
    {
      "verse_num": "7",
      "segments": [
        {
          "type": "narrative",
          "text": "But I drew his own sword and beheaded him, and removed reproach from the children of Israel."
        }
      ],
      "footnotes": [],
      "references": []
    }
  ]
}